# ═══════════════════════════════════════════════════════════
#  3D Forge — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Trend Detection ──────────────────────────────────────
# Serper API (Google Images + Google Trends search)
# Free: 2,500 searches/mo  |  Paid: $50/mo for 50K
# Sign up: https://serper.dev
SERPER_API_KEY=

# Etsy Open API v3 (trending products, optional)
# Free: 2,500 calls/day
# Sign up: https://www.etsy.com/developers
ETSY_API_KEY=

# Reddit (optional custom user agent)
REDDIT_USER_AGENT=3DForge/1.0

# ── Reference Image Sources ──────────────────────────────
# Unsplash API (free, 50 req/hr)
# Sign up: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── LLM (Concept Generation + Visual QA) ─────────────────
# OpenAI API (GPT-4o vision for image analysis)
# Required for concept generation and visual validation
# Sign up: https://platform.openai.com
OPENAI_API_KEY=

# ── Blender MCP Connection ────────────────────────────────
# The Blender addon listens on this port
BLENDER_MCP_HOST=127.0.0.1
BLENDER_MCP_PORT=9876

# ── Image-to-3D APIs (Phase 3, optional) ─────────────────
# Meshy AI — game-ready 3D from images
# $20/mo for 200 credits
# Sign up: https://www.meshy.ai
MESHY_API_KEY=

# Tripo 3D — high-quality 3D from images
# $10/mo starter
# Sign up: https://www.tripo3d.ai
TRIPO_API_KEY=

# ── Debug ─────────────────────────────────────────────────
DEBUG=
