{
  "name": "openclaw-blender-mcp",
  "version": "1.0.0",
  "description": "Control Blender via AI prompts through MCP — includes 3D Forge production pipeline for trending asset generation",
  "private": true,
  "scripts": {
    "── 3D FORGE PIPELINE ──": "",
    "forge:run": "node scripts/3d-forge/forge-orchestrator.js --full",
    "forge:run:dry": "node scripts/3d-forge/forge-orchestrator.js --full --dry-run",
    "forge:run:limit": "node scripts/3d-forge/forge-orchestrator.js --full --limit 3",
    "forge:run:deep": "node scripts/3d-forge/forge-orchestrator.js --full --limit 10",
    "forge:run:mega": "node scripts/3d-forge/forge-orchestrator.js --full --limit 15",
    "forge:gate": "node scripts/3d-forge/quality-gate-runner.js --max-retries 3",
    "forge:full:with-gates": "node scripts/3d-forge/forge-orchestrator.js --full --limit 8 && node scripts/3d-forge/quality-gate-runner.js --max-retries 2",
    "── INDIVIDUAL STAGES ──": "",
    "forge:scan": "node scripts/3d-forge/trend-scanner.js",
    "forge:scan:dry": "node scripts/3d-forge/trend-scanner.js --dry-run",
    "forge:harvest": "node scripts/3d-forge/image-harvester.js",
    "forge:harvest:dry": "node scripts/3d-forge/image-harvester.js --dry-run",
    "forge:generate": "node scripts/3d-forge/concept-generator.js",
    "forge:generate:dry": "node scripts/3d-forge/concept-generator.js --dry-run",
    "forge:produce": "node scripts/3d-forge/blender-producer.js --all-pending",
    "forge:produce:dry": "node scripts/3d-forge/blender-producer.js --all-pending --dry-run",
    "forge:produce:norender": "node scripts/3d-forge/blender-producer.js --all-pending --skip-render",
    "forge:validate": "node scripts/3d-forge/asset-validator.js --all-pending --auto-fix",
    "forge:validate:strict": "node scripts/3d-forge/asset-validator.js --all-pending --auto-fix --shot-gates --strict-shot-gates --ci-samples 3",
    "forge:validate:dry": "node scripts/3d-forge/asset-validator.js --all-pending --dry-run",
    "forge:validate:mechanical": "node scripts/3d-forge/asset-validator.js --all-pending --skip-visual",
    "── AUTORESEARCH ──": "",
    "forge:autoresearch": "node scripts/3d-forge/autoresearch-agent.js",
    "forge:autoresearch:dry": "node scripts/3d-forge/autoresearch-agent.js --dry-run",
    "forge:autoresearch:verbose": "node scripts/3d-forge/autoresearch-agent.js --verbose",
    "── RENDER QUALITY & IMPROVEMENT ──": "",
    "render:score": "node scripts/3d-forge/render-quality-scorer.js --all-exports --tier auto",
    "render:score:fast": "node scripts/3d-forge/render-quality-scorer.js --all-exports --tier 1",
    "render:score:image": "node scripts/3d-forge/render-quality-scorer.js --image",
    "render:improve": "node scripts/3d-forge/render-improvement-loop.js --all-below 60 --max-iterations 3",
    "render:improve:asset": "node scripts/3d-forge/render-improvement-loop.js --asset-id",
    "render:improve:dry": "node scripts/3d-forge/render-improvement-loop.js --all-below 60 --dry-run",
    "render:improve:report": "node scripts/3d-forge/render-improvement-loop.js --report",
    "── RENDER TESTING ──": "",
    "render:test": "node scripts/3d-forge/render-test-suite.js",
    "render:test:smoke": "node scripts/3d-forge/render-test-suite.js --smoke",
    "render:test:regression": "node scripts/3d-forge/render-test-suite.js --regression",
    "render:test:quality": "node scripts/3d-forge/render-test-suite.js --quality",
    "render:test:performance": "node scripts/3d-forge/render-test-suite.js --performance",
    "render:test:integration": "node scripts/3d-forge/render-test-suite.js --integration",
    "render:test:no-blender": "node scripts/3d-forge/render-test-suite.js --skip-blender",
    "render:test:dry": "node scripts/3d-forge/render-test-suite.js --dry-run",
    "── PARTIAL PIPELINE ──": "",
    "forge:scan-only": "node scripts/3d-forge/forge-orchestrator.js --scan-only",
    "forge:produce-only": "node scripts/3d-forge/forge-orchestrator.js --produce-only",
    "forge:validate-only": "node scripts/3d-forge/forge-orchestrator.js --validate-only",
    "forge:temporal": "node scripts/3d-forge/temporal-audit.js",
    "forge:regression": "node scripts/3d-forge/regression-suite.js",
    "forge:baseline:compare": "node scripts/3d-forge/baseline-compare.js",
    "forge:checkpoints:list": "node scripts/3d-forge/checkpoint-cli.js --action list --run-id latest",
    "── SMART PIPELINE ──": "",
    "render:smart": "node scripts/smart_render_pipeline.js --scenes 1,2,3,4 --output-dir renders/latest",
    "render:smart:dry": "node scripts/smart_render_pipeline.js --scenes 1,2,3,4 --dry-run",
    "render:smart:fast": "node scripts/smart_render_pipeline.js --scenes 1,2,3,4 --skip-vision",
    "render:smart:scene": "node scripts/smart_render_pipeline.js --scenes",
    "render:validate": "node -e \"const {execSync}=require('child_process'); [1,2,3,4].forEach(s => { console.log('Scene '+s+':'); console.log(execSync('/Applications/Blender.app/Contents/MacOS/Blender --background renders/v11_scene'+s+'.blend --python scripts/pre_render_validator.py -- --output /tmp/validate_scene'+s+'.json 2>/dev/null').toString()); })\"",
    "render:vision": "node scripts/3d-forge/vision-llm-scorer.js --batch renders/v21_final/",
    "render:vision:image": "node scripts/3d-forge/vision-llm-scorer.js --image",
    "── BLENDER INSTANCE POOL ──": "",
    "pool:status": "node scripts/blender-instance-pool.js --status",
    "pool:health": "node scripts/blender-instance-pool.js --health",
    "pool:ensure": "node scripts/blender-instance-pool.js --ensure 3",
    "pool:ensure:2": "node scripts/blender-instance-pool.js --ensure 2",
    "pool:launch": "node scripts/blender-instance-pool.js --launch",
    "pool:reset": "node scripts/blender-instance-pool.js --reset",
    "pool:lease": "node scripts/blender-instance-pool.js --lease",
    "pool:release": "node scripts/blender-instance-pool.js --release",
    "pool:json": "node scripts/blender-instance-pool.js --json",
    "── BLENDER MCP ──": "",
    "mcp:start": "python3 server/blender_mcp_server.py",
    "mcp:test": "python3 tests/qa_runner.py",
    "mcp:healthcheck": "python3 scripts/blender_healthcheck.py",
    "mcp:healthcheck:live": "python3 scripts/blender_healthcheck.py --live",
    "blender:ensure:render-qa": "python3 scripts/ensure_render_qa_ready.py",
    "blender:test:no-flake": "python3 scripts/test_no_flake.py",
    "blender:qa:render": "python3 scripts/ensure_render_qa_ready.py && python3 scripts/render_qa_cli.py",
    "blender:qa:render:strict": "python3 scripts/ensure_render_qa_ready.py && python3 scripts/render_qa_cli.py --strict --min-score 85 --max-failed 0 --max-warnings 2",
    "blender:qa:render:json": "python3 scripts/render_qa_cli.py --json-out /tmp/openclaw-render-qa.json",
    "── PRODUCT ANIMATION ──": "",
    "product:turntable": "python3 scripts/product_animation_recipes.py --recipe luxury_turntable",
    "product:hero": "python3 scripts/product_animation_recipes.py --recipe hero_reveal",
    "product:detail": "python3 scripts/product_animation_recipes.py --recipe detail_inspection",
    "product:360": "python3 scripts/product_animation_recipes.py --recipe ecommerce_360",
    "product:reel": "python3 scripts/product_animation_recipes.py --recipe social_media_reel",
    "── COMMERCIAL SEQUENCES ──": "",
    "commercial:apple": "python3 scripts/product_commercial_sequence.py --preset apple_style",
    "commercial:tech": "python3 scripts/product_commercial_sequence.py --preset tech_product",
    "commercial:jewelry": "python3 scripts/product_commercial_sequence.py --preset luxury_jewelry",
    "commercial:ecommerce": "python3 scripts/product_commercial_sequence.py --preset ecommerce_quick",
    "commercial:beauty": "python3 scripts/product_commercial_sequence.py --preset cosmetics_beauty",
    "commercial:social": "python3 scripts/product_commercial_sequence.py --preset social_media_short",
    "blender:autoresearch": "node scripts/autoresearch-blender-expertise.js",
    "blender:autoresearch:dry": "node scripts/autoresearch-blender-expertise.js --dry-run",
    "blender:autoresearch:benchmark": "node scripts/autoresearch-blender-expertise.js --benchmark",
    "blender:autoresearch:report": "node scripts/autoresearch-blender-expertise.js --report",
    "blender:autoresearch:scan": "node scripts/autoresearch-blender-expertise.js --scan-only",
    "forge:hof:list": "node scripts/3d-forge/hall-of-failures-manager.js --action list",
    "forge:hof:add": "node scripts/3d-forge/hall-of-failures-manager.js --action add",
    "── PARALLEL RENDER WORKERS (Ollama LLM-driven) ──": "",
    "render:worker": "node scripts/3d-forge/render-improve-loop.js --max-iterations=10",
    "render:worker:quick": "node scripts/3d-forge/render-improve-loop.js --max-iterations=3",
    "render:worker:parallel": "bash scripts/3d-forge/run-parallel-workers.sh 3 5",
    "render:worker:parallel:heavy": "bash scripts/3d-forge/run-parallel-workers.sh 5 10",
    "render:audit": "node scripts/3d-forge/render-audit-supervisor.js",
    "render:worker:status": "cat reports/worker_audit_latest.json 2>/dev/null || echo '{\\\"error\\\": \\\"no audit yet\\\"}' ",
    "render:worker:experiments": "tail -20 data/worker_experiments.ndjson 2>/dev/null || echo 'No experiments yet' "
  },
  "keywords": [
    "blender",
    "mcp",
    "3d-printing",
    "stl",
    "roblox-ugc",
    "game-assets",
    "ai-3d",
    "trend-detection",
    "autoresearch"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "sharp": "^0.33.5",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "gltf-validator": "^2.0.0-dev.3.10"
  }
}
