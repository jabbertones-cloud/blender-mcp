  "scoring_method": {
    "description": "Composite scoring method combining 5 weighted metrics. Each metric produces a 0-10 score; final score is weighted average.",
    "overall_formula": "sum(metric_score * metric_weight) where sum(weights) = 1.0",
    "metrics": {
      "histogram_similarity": {
        "weight": 0.20,
        "target_range": [7.0, 10.0],
        "method": "chi_squared_distance",
        "description": "Compares luminance and color channel distributions against gold reference",
        "implementation": {
          "algorithm": "chi_squared_distance",
          "channels": ["L", "a", "b"],
          "bins": 256,
          "threshold_perfect": 0.7,
          "threshold_acceptable": 0.5,
          "scoring": "linear_0_to_10_from_threshold_to_1.0"
        },
        "tolerance": {
          "brightness_mean_delta": 5,
          "color_channel_balance_delta": 0.02,
          "entropy_delta": 0.5
        }
      },
      "edge_density_match": {
        "weight": 0.20,
        "target_range": [6.5, 10.0],
        "method": "canny_edge_detection_pixel_ratio_comparison",
        "description": "Validates edge clarity in evidence zones using Canny edge detection",
        "implementation": {
          "algorithm": "canny_edge_detector",
          "sigma": 1.4,
          "threshold_low": 0.1,
          "threshold_high": 0.3,
          "target_edge_ratio": [0.08, 0.25],
          "zone_analysis": true,
          "scoring": "per_zone_weighted_average"
        },
        "zone_weights": {
          "impact_point": 0.35,
          "vehicle_contact": 0.30,
          "evidence_markers": 0.25,
          "background": 0.10
        }
      },
      "contrast_profile_match": {
        "weight": 0.15,
        "target_range": [7.0, 10.0],
        "method": "local_contrast_map_correlation",
        "description": "Evaluates local and global contrast using Michelson contrast metrics",
        "implementation": {
          "algorithm": "local_binary_patterns_contrast",
          "window_size": 32,
          "dynamic_range_target": [0.6, 0.85],
          "local_contrast_target": [0.30, 0.65],
          "correlation_metric": "pearson"
        },
        "micro_contrast_analysis": {
          "enabled": true,
          "texture_sharpness_check": true,
          "detail_preservation": "high"
        }
      },
      "evidence_visibility": {
        "weight": 0.25,
        "target_range": [7.0, 10.0],
        "method": "region_brightness_and_contrast_check_per_marker",
        "description": "Forensic-specific: Validates that all required evidence markers are visible and legible",
        "implementation": {
          "marker_detection": "template_matching_and_manual_annotation",
          "visibility_criteria": {
            "brightness_delta_from_background": 15,
            "contrast_ratio_minimum": 1.5,
            "edge_clarity_score": 0.7,
            "label_legibility_pixels": 12
          },
          "required_markers_pass_threshold": 1.0
        },
        "per_marker_validation": {
          "impact_point_label": {"criticality": "high", "weight": 0.30},
          "vehicle_positions": {"criticality": "high", "weight": 0.25},
          "scale_reference": {"criticality": "high", "weight": 0.20},
          "sight_lines": {"criticality": "medium", "weight": 0.15},
          "coordinate_system": {"criticality": "medium", "weight": 0.10}
        }
      },
      "composition_balance": {
        "weight": 0.20,
        "target_range": [6.5, 10.0],
        "method": "rule_of_thirds_alignment_and_spatial_distribution",
        "description": "Ensures forensically appropriate composition: evidence in focus, witness perspectives clear",
        "implementation": {
          "algorithm": "entropy_distribution_analysis",
          "rule_of_thirds_grid": true,
          "focal_point_analysis": true,
          "depth_distribution": true
        },
        "forensic_composition_rules": {
          "impact_zone_framing": "center_or_upper_third",
          "witness_perspective_visible": true,
          "environmental_context_clear": true,
          "spatial_depth_conveyed": true,
          "evidence_hierarchy_visual": true
        }
      }
    }
  },
  "drift_detection": {
    "description": "Automated quality drift detection triggers review when scores deviate significantly from gold baseline across multiple cycles",
    "enabled": true,
    "max_drift_percentage": 15,
    "drift_calculation": "percentage_change_from_baseline_average",
    "baseline_samples": 5,
    "min_cycles_before_alert": 3,
    "alert_conditions": {
      "overall_score_drift": {
        "threshold_percentage": 15,
        "trigger_cycles": 3,
        "action": "flag_for_investigation"
      },
      "track_score_drift": {
        "threshold_percentage": 20,
        "trigger_cycles": 2,
        "action": "isolate_degraded_track"
      },
      "histogram_drift": {
        "threshold_chi_squared": 1.2,
        "trigger_cycles": 3,
        "action": "check_lighting_setup"
      },
      "edge_density_drift": {
        "threshold_percentage": 25,
        "trigger_cycles": 2,
        "action": "review_material_sharpness"
      }
    },
    "recovery_protocol": {
      "compare_against": "last_known_good_version",
      "snapshot_frequency_cycles": 5,
      "rollback_available": true,
      "notification_targets": ["qa_lead", "render_supervisor"]
    }
  },
